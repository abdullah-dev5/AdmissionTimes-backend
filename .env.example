# Server Configuration
PORT=3000
NODE_ENV=development
API_VERSION=v1
CORS_ORIGIN=*

# Database Configuration (Supabase PostgreSQL)
DB_HOST=db.lufhgsgubvxjrrcsevte.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_database_password_here
DB_POOL_MAX=20

# Supabase Configuration
SUPABASE_URL=https://lufhgsgubvxjrrcsevte.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# JWT Configuration (JWKS Authentication)
JWT_ALGORITHM=RS256
JWT_ISSUER=https://lufhgsgubvxjrrcsevte.supabase.co/auth/v1
JWT_AUDIENCE=authenticated
JWT_JWKS_URL=https://lufhgsgubvxjrrcsevte.supabase.co/.well-known/jwks.json
JWT_EXPIRY_TOLERANCE=300

# Email Configuration (Phase 2: Nodemailer)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_16_character_app_password
EMAIL_FROM=your_gmail_address@gmail.com

# Realtime Configuration (Phase 2: Supabase Realtime)
REALTIME_ENABLED=false

# Scraper Integration (Internal ingestion)
SCRAPER_INTEGRATION_ENABLED=false
SCRAPER_PUBLISH_ENABLED=false
SCRAPER_INTERNAL_SERVICE_TOKEN=
