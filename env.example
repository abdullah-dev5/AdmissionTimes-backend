# Server Configuration
PORT=3000
NODE_ENV=development
API_VERSION=v1

# CORS Configuration
# For development: use '*' to allow all origins, or specify frontend URL(s)
# For production: specify exact frontend URL(s), comma-separated for multiple
# Examples:
#   CORS_ORIGIN=http://localhost:5173
#   CORS_ORIGIN=http://localhost:5173,https://yourdomain.com
CORS_ORIGIN=*

# Database Configuration
DB_HOST=localhost
DB_PORT=54322
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MAX=20
