# Server Configuration
PORT=3000
NODE_ENV=development
API_VERSION=v1

# CORS Configuration
# For development: use '*' to allow all origins, or specify frontend URL(s)
# For production: specify exact frontend URL(s), comma-separated for multiple
# Examples:
#   CORS_ORIGIN=http://localhost:5173
#   CORS_ORIGIN=http://localhost:5173,https://yourdomain.com
CORS_ORIGIN=*

# Database Configuration
DB_HOST=localhost
DB_PORT=54322
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MAX=20

# ============================================================================
# Supabase Configuration (Phase 1: JWKS Verification)
# ============================================================================
# Get these values from your Supabase project settings:
# - SUPABASE_URL: Project URL
# - SUPABASE_ANON_KEY: Anon/Public Key
# - SUPABASE_SERVICE_ROLE_KEY: Service Role Key (for admin operations)
# - SUPABASE_JWT_SECRET: JWT Secret (for verification)

SUPABASE_URL=https://lufhgsgubvxjrrcsevte.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-jwt-secret-key-here

# ============================================================================
# JWT Configuration (Phase 1: JWKS Signature Verification)
# ============================================================================
# These match your Supabase project for signature verification
# Algorithm: RS256 (production) | HS256 (development fallback)

JWT_ALGORITHM=RS256
JWT_ISSUER=https://lufhgsgubvxjrrcsevte.supabase.co/auth/v1
JWT_AUDIENCE=authenticated
JWT_JWKS_URL=https://lufhgsgubvxjrrcsevte.supabase.co/.well-known/jwks.json
JWT_EXPIRY_TOLERANCE=300